generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  STAFF
  MEMBER
}

enum MemberStatus {
  ACTIVE
  PROSPECT
  INACTIVE
  PAUSED
}

enum EventType {
  CLASS
  PRIVATE
  CLINIC
  CAMP
  TOURNAMENT
  OTHER
}

enum BookingStatus {
  CONFIRMED
  WAITLISTED
  CANCELED
  ATTENDED
  NO_SHOW
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Club {
  id                       String    @id @default(cuid())
  name                     String
  slug                     String    @unique
  // Plans: growth | pro | enterprise. There is no free/Starter tier — every
  // club is on at least Growth. Definitions live in lib/tier.ts.
  tier                     String    @default("growth")
  // When true, Stripe processing fees are transparently added to the
  // member/customer's checkout total so the club nets the full amount.
  // Centralized math lives in lib/fees.ts — never hardcode the % elsewhere.
  passProcessingFees       Boolean   @default(false)
  processingFeeNote        String?
  tagline                  String?
  sport                    String?
  primaryColor             String?   @default("#534AB7")
  logoUrl                  String?
  // Branded mobile-app configuration (owner-customizable). Shape:
  // { appName, shortDescription, iconUrl, themeColor, splashColor,
  //   iosBundleId, androidPackage, enabled }
  brandedAppConfig         Json?
  // Stripe Connect (the club's own Stripe account that receives payments)
  stripeAccountId          String?   @unique
  stripeOnboardingComplete Boolean   @default(false)
  stripeChargesEnabled     Boolean   @default(false)
  stripePayoutsEnabled     Boolean   @default(false)
  // ClubOS subscription billing (when the club pays us monthly)
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  subscriptionStatus       String?
  // Plaid bank integration lives on the PlaidConnection model now (one row
  // per linked bank). The legacy single-account fields were dropped in
  // migration 20260608000000_drop_legacy_plaid_columns.
  notificationPrefs        Json      @default("{}")
  // Member intake form configuration
  // { enabledFields: string[], requiredFields: string[] }
  // When null, the form is in "default" mode (Athlete Name + Email only).
  memberFormConfig         Json?
  // Long-form About Us content for the member portal
  aboutUs                  String?
  // Public-facing club profile
  coverImageUrl            String?
  contactEmail             String?
  contactPhone             String?
  websiteUrl               String?
  // Outgoing email identity. emailFromName is the friendly "From" name
  // members see (defaults to the club name). emailReplyTo is where member
  // replies go (defaults to contactEmail).
  emailFromName            String?
  emailReplyTo             String?
  // Branded App personalization (member portal look + copy). All optional —
  // null means use the AthletixOS defaults.
  //   appFontFamily : CSS font-family stack, e.g. "Inter, sans-serif".
  //   appTextAlign  : "left" | "center" | "right" (applied to portal copy).
  //   appHomeContent: free text/markdown shown as a welcome block on the
  //                   member portal home.
  //   appCopy       : map of override strings { key: value } the portal can
  //                   read to swap built-in copy (e.g. {"welcome":"Hey ..."}).
  appFontFamily            String?
  appTextAlign             String?
  appHomeContent           String?
  appCopy                  Json?
  // Owner-controlled "what billing info do members see on their portal."
  // Shape: { showPlan, showNextBilling, showPrice, showInvoices } booleans.
  // null = use defaults (everything visible). Lets a club hide pricing /
  // next-charge dates from members when the owner handles billing offline.
  memberBillingVisibility  Json?
  // Owner overrides for the built-in EventType badge colors. Shape:
  //   { CLASS:{bg,fg}, PRIVATE:{bg,fg}, CLINIC:{bg,fg}, CAMP:{bg,fg},
  //     TOURNAMENT:{bg,fg}, OTHER:{bg,fg} }
  // Any missing key falls back to the hardcoded defaults. Custom
  // ClubEventType colors take precedence over both.
  builtInEventColors       Json?
  campaigns                  Campaign[]
  campaignAttributions       CampaignAttribution[]
  // JSON array of {label, url} pairs (Instagram, Facebook, YouTube, …)
  socialLinks              Json      @default("[]")
  // JSON map of {monday: "9-5", tuesday: "...", ...} or free-form blob
  hoursOfOperation         Json?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?

  locations                   Location[]
  users                       User[]
  members                     Member[]
  memberships                 Membership[]
  events                      Event[]
  messages                    Message[]
  announcements               Announcement[]
  announcementEngagements     AnnouncementEngagement[]
  groupMessageReceipts        GroupMessageReceipt[]
  transactions                Transaction[]
  documents                   Document[]
  customFields                CustomField[]
  clubEventTypes              ClubEventType[]
  expenses                    Expense[]
  messageGroups               MessageGroup[]
  clubProfile                 ClubProfile?
  legalEntities               LegalEntity[]
  donationLinks               DonationLink[]
  donations                   Donation[]
  // Optional fallback entity stamped on money records when none is chosen.
  defaultLegalEntityId        String?
  discounts                   Discount[]
  products                    Product[]
  productSales                ProductSale[]
  uploadedFiles               UploadedFile[]
  emailOptOuts                EmailOptOut[]
  eventRegistrations          EventRegistration[]
  eventBundles                EventBundle[]
  contractors                 Contractor[]
  contractorPayments          ContractorPayment[]
  memberMigrationEvents       MemberMigrationEvent[]
  privateLessonTypes          PrivateLessonType[]
  privatePackages             PrivatePackage[]
  staffAvailability           StaffAvailability[]
  staffAvailabilityExceptions StaffAvailabilityException[]
  eventStaffAssignments       EventStaffAssignment[]
  privateLessonPayRates       PrivateLessonPayRate[]
  privateBookings             PrivateBooking[]
  privateBookingPartners      PrivateBookingPartner[]
  staffDocuments              StaffDocument[]
  privateCreditLedger         PrivateCreditLedger[]
  recurringClasses            RecurringClass[]
  classSessions               ClassSession[]
  attendanceRecords           AttendanceRecord[]
  memberRelationships         MemberRelationship[]
  staffCompensations          StaffCompensation[]
  plaidConnections            PlaidConnection[]
  pendingApprovals            PendingApproval[]
  legalAcceptances            LegalAcceptance[]

  @@index([slug])
  @@map("clubs")
}

// One row per Plaid Item the club connects. Lets a club link multiple
// bank accounts (operating, foundation, savings, …) instead of being
// limited to a single Plaid access token on Club. The legacy
// `Club.plaidAccessToken` columns stay for back-compat and are migrated
// lazily into a PlaidConnection row on first read.
model PlaidConnection {
  id              String   @id @default(cuid())
  clubId          String
  // Owner-chosen friendly name. Falls back to the institution name from
  // Plaid when null.
  label           String?
  institutionName String?
  accessToken     String
  itemId          String   @unique
  // Optional cache so the UI doesn't have to hit Plaid every render.
  accountsCache   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  club         Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  expenses     Expense[]

  @@index([clubId])
  @@map("plaid_connections")
}

// Per-action gate for minors with parentControls.requirePaymentApproval.
// When a minor tries to book a paid class / event / private / package, we
// don't charge or hold capacity — we write one of these rows + notify the
// guardian. Approval flips status to APPROVED and the booking flow replays
// the original payload. Decline or 7-day expiry closes it. The actual
// booking/charge logic lives in the booking endpoints; this table just
// stores the intent + the replay payload.
model PendingApproval {
  id            String   @id @default(cuid())
  clubId        String
  memberId      String
  // Member-side (parental) kinds, surfaced in the family-approvals card:
  //   CLASS_BOOK | EVENT_REGISTER | PRIVATE_REQUEST | PACKAGE_BUY
  //   | MEMBERSHIP_SUBSCRIBE | PRODUCT_BUY | OTHER
  // Owner-side kind, surfaced only on the dashboard (never to members):
  //   GUARDIAN_LINK -> a User requesting guardian access to this member
  kind          String
  // Replay payload — shape varies by kind:
  //   CLASS_BOOK     -> { classSessionId }
  //   EVENT_REGISTER -> { eventId, sessionId? }
  //   PRIVATE_REQUEST-> { lessonTypeId, coachId?, requestedSlots[] }
  //   PACKAGE_BUY    -> { packageId }
  //   GUARDIAN_LINK  -> { requestingUserId, requestingUserEmail, relationship? }
  payload       Json
  // Optional dollar amount captured at request time. Powers the
  // dailySpendLimit cap check + the parent-side summary. Null for free
  // or amount-unknown actions.
  amount        Decimal? @db.Decimal(10, 2)
  // PENDING | APPROVED | DECLINED | EXPIRED
  status        String   @default("PENDING")
  requestedAt   DateTime @default(now())
  respondedAt   DateTime?
  // Which guardian User responded. Null until status changes from PENDING.
  respondedById String?

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([memberId, status])
  @@map("pending_approvals")
}

model Location {
  id        String    @id @default(cuid())
  clubId    String
  name      String
  address   String?
  // GPS coordinates so member-facing surfaces can deep-link to Apple/Google Maps.
  latitude  Float?
  longitude Float?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  club               Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  events             Event[]
  legalEntities      LegalEntity[]
  privateLessonTypes PrivateLessonType[]
  recurringClasses   RecurringClass[]

  @@index([clubId])
  @@map("locations")
}

model User {
  id            String    @id @default(cuid())
  clubId        String
  email         String
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole  @default(MEMBER)
  emailVerified DateTime?
  resetToken    String?   @unique
  resetExpires  DateTime?
  lastLoginAt   DateTime?
  // Per-user dashboard widget preferences: { order: string[], hidden: string[] }.
  // Null = use sensible defaults.
  dashboardWidgets Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  club                    Club                         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  staffProfile            StaffProfile?
  memberProfile           Member?
  guardianProfile         Guardian?                    @relation("GuardianUser")
  guardianOf              MemberGuardianUser[]         @relation("GuardianLink")
  sentMessages            Message[]                    @relation("Sender")
  receivedMessages        Message[]                    @relation("Recipient")
  announcementEngagements AnnouncementEngagement[]
  messageGroupMemberships MessageGroupMember[]
  sentGroupMessages       GroupMessage[]               @relation("GroupSender")
  groupMessageReceipts    GroupMessageReceipt[]
  availability            StaffAvailability[]
  availabilityExceptions  StaffAvailabilityException[]
  eventAssignments        EventStaffAssignment[]
  coachBookings           PrivateBooking[]             @relation("CoachBookings")
  privateLessonPayRates   PrivateLessonPayRate[]
  attendanceAdded         AttendanceRecord[]           @relation("AttendanceAddedBy")
  documentSignatures      DocumentSignature[]
  uploadedFiles           UploadedFile[]
  compensation            StaffCompensation?
  staffDocuments          StaffDocument[]              @relation("StaffDocsTarget")
  uploadedStaffDocs       StaffDocument[]              @relation("StaffDocsUploader")
  legalAcceptances        LegalAcceptance[]

  @@unique([clubId, email])
  @@index([clubId])
  @@index([email])
  @@map("users")
}

// Audit-grade record of Terms of Service + Privacy Policy acceptance.
// One row per (user, documentType) acceptance event. New acceptance of a
// new version creates a new row — we never overwrite history. Two rows are
// written per signup (TOS + PRIVACY). Source-of-truth versions live in
// legal/versions.ts (TERMS_VERSION + PRIVACY_VERSION).
model LegalAcceptance {
  id           String   @id @default(cuid())
  userId       String
  clubId       String?
  documentType String   // "TOS" | "PRIVACY"
  version      String   // e.g. "2026-06-05-draft"
  acceptedAt   DateTime @default(now())
  ipAddress    String?
  userAgent    String?

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club? @relation(fields: [clubId], references: [id], onDelete: SetNull)

  @@index([userId, documentType])
  @@index([clubId, documentType])
  @@map("legal_acceptances")
}

// Documents the owner uploads to a staff member's profile — tax docs
// (W-9, 1099), contracts, agreements, certifications. Owner controls
// whether the staff member can see/download each one via sharedWithStaff.
// Files live in the existing private /api/upload + /api/files/[id] store.
model StaffDocument {
  id               String   @id @default(cuid())
  clubId           String
  // The staff USER this document belongs to (target).
  userId           String
  // Optional link to the underlying UploadedFile; URL is stored independently
  // so back-compat /public/uploads paths still work.
  fileId           String?
  fileUrl          String
  fileName         String?
  mimeType         String?
  sizeBytes        Int?
  title            String
  // W9 | 1099 | CONTRACT | AGREEMENT | CERTIFICATION | OTHER
  kind             String   @default("OTHER")
  notes            String?
  // Owner choice: false = owner-only; true = visible to the staff member.
  sharedWithStaff  Boolean  @default(false)
  uploadedById     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  club       Club  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user       User  @relation("StaffDocsTarget",   fields: [userId],       references: [id], onDelete: Cascade)
  uploadedBy User? @relation("StaffDocsUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([clubId])
  @@index([userId])
  @@map("staff_documents")
}

model StaffProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  title            String?
  hourlyRate       Decimal? @db.Decimal(10, 2)
  salary           Decimal? @db.Decimal(10, 2)
  appointmentPrice Decimal? @db.Decimal(10, 2)
  // Flat pay per class session taught (in addition to / instead of hourly).
  perSessionRate   Decimal? @db.Decimal(10, 2)
  permissions      Json     @default("{}")
  // Member-portal bio + visible contact (only shown when showOnPortal=true)
  bio              String?
  publicEmail      String?
  publicPhone      String?
  photoUrl         String?
  showOnPortal     Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_profiles")
}

model Member {
  id                   String       @id @default(cuid())
  clubId               String
  userId               String?      @unique
  firstName            String
  lastName             String
  dateOfBirth          DateTime?
  status               MemberStatus @default(PROSPECT)
  membershipId         String?
  tags                 String       @default("")
  notes                String?
  customFieldValues    String       @default("{}")
  joinedAt             DateTime     @default(now())
  email                String?
  phone                String?
  streetAddress        String?
  city                 String?
  state                String?
  zipCode              String?
  gender               String?
  stripeCustomerId     String?
  profileImageUrl      String?
  // Lightweight lead attribution for the Campaigns dashboard. Defaults keep
  // existing members in the funnel without forcing owners to classify them.
  leadSource           String       @default("UNKNOWN")
  leadStage            String       @default("NEW")
  leadSourceUpdatedAt  DateTime?
  // Minor / guardian fields
  isMinor              Boolean      @default(false)
  guardianName         String?
  guardianEmail        String?
  guardianPhone        String?
  guardianRelationship String?

  // ── Parental controls (P4) ─────────────────────────────────────────────
  // When non-null, the member's date of birth is read-only — only an owner
  // or guardian can change it via a server-side action that clears this
  // field first. Prevents minors from editing their DOB to bypass age gates.
  birthdayLockedAt     DateTime?
  // Per-minor parent controls. Shape:
  //   {
  //     requirePaymentApproval: boolean,  // gate paid bookings on guardian approval
  //     monitoredMessaging:     boolean,  // notify guardian on every DM
  //     allowPackagePurchase:   boolean,  // false = pkg buy hits approval queue
  //     dailySpendLimit?:       number    // dollars/day before approval kicks in
  //   }
  // Null = no controls = existing behavior. Stored as JSON so we can extend
  // without a migration each time.
  parentControls       Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  deletedAt            DateTime?

  guardianId String?

  // ── Member migration / software-switch ──────────────────────────────────
  // Populated when a member is brought over from another club platform via the
  // migration wizard. Never tier-gated. Imported members are NEVER auto-charged
  // — billing only starts after they activate and add a payment method.
  legacySource             String? // e.g. "Jackrabbit", "Mindbody", "Spreadsheet"
  legacyMemberId           String? // their ID in the old system (for support)
  importedAt               DateTime?
  // null = not a migrated member.
  // IMPORTED | INVITED | ACTIVATED | COMPLETED | FAILED | NEEDS_REVIEW
  migrationStatus          String?
  // null | REQUIRED | COMPLETE
  paymentSetupStatus       String?
  // Legacy membership snapshot (display only until activation creates the sub)
  legacyMembershipName     String?
  legacyMembershipPrice    Decimal? @db.Decimal(10, 2)
  legacyBillingFrequency   String? // WEEKLY | MONTHLY | QUARTERLY | ANNUAL | ...
  membershipStartDate      DateTime?
  nextBillingDate          DateTime?
  // THE key field: when Stripe should take the first charge so billing
  // continues on the member's existing cycle (not on import day).
  billingAnchorDate        DateTime?
  commitmentEndDate        DateTime?
  // Secure activation link
  activationToken          String?  @unique
  activationTokenExpires   DateTime?
  activationEmailSentAt    DateTime?
  activationEmailSendCount Int      @default(0)
  activatedAt              DateTime?
  migrationCompletedAt     DateTime?
  // Owner-assigned plan this migration continues (a real Membership.id).
  // Preferred over the legacy* snapshot when set.
  migrationMembershipId    String?
  // Owner price override set BEFORE the activation link is sent. When non-null
  // this is the exact recurring price the migrated member pays — it wins over
  // both the legacy snapshot price and the assigned plan's option price.
  migrationPriceOverride   Decimal? @db.Decimal(10, 2)
  // Free-text note for why (e.g. "Founding member 20% off"). Display only.
  migrationDiscountNote    String?
  // Owner flag: this member is in their already-paid final period. The
  // activation link then shows "active through <commitmentEndDate>", collects
  // no card, and completes as a non-renewing membership (no subscription).
  migrationFinalPeriodPaid Boolean  @default(false)
  // Which fields/abilities the client may edit on the activation page.
  // Shape: { phone, email, billingDateRequest, notes }. null = defaults.
  activationEditableFields Json?
  // Client-submitted requests captured at activation (owner reviews these).
  requestedBillingDate       DateTime?
  requestedBillingNote       String?
  activationNote             String?
  // Member-set at registration; owner reviews. On approval this becomes the
  // membership's commitmentEndDate (and the subscription's cancel_at).
  requestedCancellationDate  DateTime?
  // "CARD" | "CASH" | "CHECK". CASH/CHECK collect no card and require full
  // owner approval before the membership is active.
  requestedPaymentMethod     String?
  // The membership option the member chose at registration:
  // { label, price, billingPeriod }. Honored over the plan's default option.
  migrationSelectedOption    Json?
  // null | PENDING_APPROVAL | APPROVED. Billing NEVER starts until APPROVED.
  approvalStatus             String?
  // Stripe Customer + PaymentMethod on the club's CONNECTED account, saved
  // via setup-mode checkout. The subscription is created from these only
  // after the owner approves — never at activation time.
  stripeSetupCustomerId      String?
  stripeSetupPaymentMethodId String?

  club              Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user              User?                 @relation(fields: [userId], references: [id])
  membership        Membership?           @relation(fields: [membershipId], references: [id])
  guardian          Guardian?             @relation(fields: [guardianId], references: [id])
  guardianLinks     MemberGuardianUser[]
  bookings          Booking[]
  transactions      Transaction[]
  subscriptions     MemberSubscription[]
  productSales      ProductSale[]
  privateCredits    PrivateCreditLedger[]
  privateBookings   PrivateBooking[]
  privateBookingPartners PrivateBookingPartner[]
  attendanceRecords AttendanceRecord[]
  documentSignatures DocumentSignature[]
  eventRegistrations EventRegistration[]
  migrationEvents    MemberMigrationEvent[]
  campaignAttributions CampaignAttribution[]
  relationshipsFrom  MemberRelationship[] @relation("RelationshipFrom")
  relationshipsTo    MemberRelationship[] @relation("RelationshipTo")
  pendingApprovals   PendingApproval[]

  @@index([clubId])
  @@index([status])
  @@index([guardianId])
  @@map("members")
}

// Append-only migration audit / history log. One row per meaningful event in a
// member's migration lifecycle (imported, activation sent, reminder, activated,
// completed, failed, note). Never deleted — preserves the legacy paper trail.
model MemberMigrationEvent {
  id        String   @id @default(cuid())
  clubId    String
  memberId  String
  // IMPORTED | ACTIVATION_SENT | REMINDER_SENT | ACTIVATED | COMPLETED |
  // FAILED | NOTE
  type      String
  message   String?
  actorUserId String?
  createdAt DateTime @default(now())

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([memberId])
  @@map("member_migration_events")
}

// A relationship between two members (siblings, cousins, friends, teammates,
// etc). Stored once per pair (memberId < relatedMemberId by convention is NOT
// enforced — the API writes one row and reads both directions). Distinct from
// Guardian/MemberGuardianUser which model legal guardianship + portal access.
model MemberRelationship {
  id              String   @id @default(cuid())
  clubId          String
  memberId        String
  relatedMemberId String
  type            String   // SIBLING | COUSIN | FRIEND | TEAMMATE | PARENT | CHILD | SPOUSE | OTHER
  note            String?
  createdAt       DateTime @default(now())

  club    Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member  Member @relation("RelationshipFrom", fields: [memberId], references: [id], onDelete: Cascade)
  related Member @relation("RelationshipTo", fields: [relatedMemberId], references: [id], onDelete: Cascade)

  @@unique([memberId, relatedMemberId])
  @@index([clubId])
  @@index([memberId])
  @@index([relatedMemberId])
  @@map("member_relationships")
}

model MemberSubscription {
  id           String @id @default(cuid())
  memberId     String
  membershipId String

  // Snapshot of what was purchased
  optionLabel   String
  price         Decimal @default(0) @db.Decimal(10, 2)
  billingPeriod String? // WEEKLY | MONTHLY | … | ONE_TIME — snapshot at purchase
  billingType   String  @default("RECURRING") // RECURRING | ONE_TIME | MANUAL

  // Dates
  startDate DateTime? // when access begins
  endDate   DateTime? // when access expires; null = open-ended recurring

  // Billing control
  autoRenew         Boolean   @default(true)
  billingDay        Int? // 1-28: override billing day of month
  billingAnchorDate DateTime? // resolved anchor datetime passed to Stripe

  // Status: pending → active → past_due → canceled | expired
  status      String    @default("pending")
  pausedAt    DateTime?
  pausedUntil DateTime?
  canceledAt  DateTime?
  expiredAt   DateTime?
  startedAt   DateTime?

  // Stripe
  stripeSubscriptionId    String? @unique
  stripePriceId           String?
  stripeCheckoutSessionId String?

  // Renewal chain — plain string ref to avoid self-relation complexity
  renewedFromId String?

  // Discount applied at purchase
  discountCode   String?
  discountAmount Decimal? @db.Decimal(10, 2)

  // Legacy start mode (kept for backward compat)
  startMode          String    @default("IMMEDIATE") // IMMEDIATE | SPECIFIC_DATE
  effectiveStartDate DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([membershipId])
  @@index([status])
  @@index([endDate])
  @@map("member_subscriptions")
}

// Family / parent profile — one per family identified by primary email.
// Each minor athlete has Member.guardianId pointing here. Adults may also link.
model Guardian {
  id        String   @id @default(cuid())
  clubId    String
  firstName String
  lastName  String
  email     String
  phone     String
  userId    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?    @relation("GuardianUser", fields: [userId], references: [id])
  members Member[]

  @@unique([clubId, email])
  @@index([clubId])
  @@map("guardians")
}

// User <-> Member link for portal access (e.g. parent user account viewing their child's member record).
// Distinct from the Guardian profile model — this records portal access claims, not the family profile.
model MemberGuardianUser {
  id           String   @id @default(cuid())
  userId       String
  memberId     String
  relationship String?
  createdAt    DateTime @default(now())

  user   User   @relation("GuardianLink", fields: [userId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([userId, memberId])
  @@map("member_guardian_users")
}

model Membership {
  id             String  @id @default(cuid())
  clubId         String
  name           String
  description    String?
  options        Json    @default("[]") // [{ label, price, billingPeriod }]
  active         Boolean @default(true)
  purchaseAccess String  @default("ANYONE") // ANYONE | STAFF_ONLY

  // Plan-level defaults & permissions
  autoRenewDefault        Boolean @default(true)
  allowManualRenewal      Boolean @default(true)
  allowCustomDates        Boolean @default(false)
  allowBillingDayOverride Boolean @default(false)
  defaultBillingDay       Int? // 1-28; null = anchor to signup date
  contractMonths          Int? // minimum commitment; null = none

  // Trial rules — when enabled, new subscribers get `trialDays` free before
  // first charge. trialAppliesToReturning controls whether a member can use a
  // trial again after a previous active subscription (default: one-time only).
  trialEnabled            Boolean @default(false)
  trialDays               Int?    // null when disabled; positive integer otherwise
  trialAppliesToReturning Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  club          Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members       Member[]
  subscriptions MemberSubscription[]

  @@index([clubId])
  @@map("memberships")
}

model CustomField {
  id        String   @id @default(cuid())
  clubId    String
  label     String
  fieldType String
  required  Boolean  @default(false)
  options   String   @default("[]")
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@map("custom_fields")
}

model ClubEventType {
  id        String   @id @default(cuid())
  clubId    String
  name      String
  color     String   @default("#F1EFE8")
  textColor String   @default("#5F5E5A")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  events Event[]

  @@index([clubId])
  @@map("club_event_types")
}

model Event {
  id                     String    @id @default(cuid())
  clubId                 String
  locationId             String?
  type                   EventType
  customEventTypeId      String?
  name                   String
  description            String?
  startsAt               DateTime
  endsAt                 DateTime
  capacity               Int?
  memberPrice            Decimal?  @db.Decimal(10, 2)
  nonMemberPrice         Decimal?  @db.Decimal(10, 2)
  dropInFee              Decimal?  @db.Decimal(10, 2)
  travelFee              Decimal?  @db.Decimal(10, 2)
  publishAt              DateTime?
  unpublishAt            DateTime?
  visibility             String    @default("PUBLIC") // PUBLIC | MEMBERS_ONLY | STAFF_ONLY
  purchaseAccess         String    @default("ANYONE") // ANYONE | STAFF_ONLY
  allowMembershipPayment Boolean   @default(false)
  imageUrl               String?
  imagePositionX Int @default(50)
  imagePositionY Int @default(50)
  isTournament           Boolean   @default(false)
  registrationLink       String?
  registrationDeadline   DateTime?
  registrationOpen       Boolean?
  divisions              String?
  pricingOptions         Json?

  // Tournament mode — only meaningful when type=TOURNAMENT.
  //   HOST   = the club is running the tournament; attach a registration form.
  //   ATTEND = the club is taking a team to someone else's tournament; gather
  //            signups and (optionally) split a shared cost across attendees.
  tournamentMode         String?   // HOST | ATTEND

  // Owner-editable registration form. Array of field defs:
  //   [{ id, label, type: "text|email|phone|textarea|select|checkbox", required, options?: string[] }]
  registrationForm       Json?

  // Public (non-member) registration via /e/[publicSlug]
  publicRegistration     Boolean   @default(false)
  publicSlug             String?   @unique
  publicFormIntro        String?
  // Which price the public registration page charges: MEMBER | NON_MEMBER |
  // DROP_IN. null = auto (non-member full price).
  publicPricingOption    String?

  // Variable cost (ATTEND tournaments): split a shared cost across attendees.
  //   ESTIMATED = charge total / estimatedSignups at signup time.
  //   OFFICIAL  = collect free signups, then bill total / actualSignups after.
  variableCostEnabled         Boolean   @default(false)
  variableCostMode            String?   // ESTIMATED | OFFICIAL
  variableCostTotal           Decimal?  @db.Decimal(10, 2)
  variableCostEstimatedSignups Int?
  // Shown to parents as a "roughly $X each" estimate even in OFFICIAL mode,
  // before the official total is known. Display-only; never billed.
  variableCostEstimatedTotal  Decimal?  @db.Decimal(10, 2)
  variableCostBilledAt        DateTime?

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  club             Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  location         Location?              @relation(fields: [locationId], references: [id])
  customEventType  ClubEventType?         @relation(fields: [customEventTypeId], references: [id])
  bookings         Booking[]
  sessions         EventSession[]
  staffAssignments EventStaffAssignment[]
  registrations    EventRegistration[]
  bundleItems      EventBundleItem[]

  @@index([clubId])
  @@index([startsAt])
  @@map("events")
}

model EventSession {
  id        String   @id @default(cuid())
  eventId   String
  name      String?
  startsAt  DateTime
  endsAt    DateTime
  sortOrder Int      @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_sessions")
}

// A signup for an Event. Covers BOTH non-member public registrations (via the
// /e/[slug] page) and member registrations. memberId is set only when an
// existing member is matched. formResponses holds answers to the event's
// owner-defined registrationForm.
model EventRegistration {
  id                      String   @id @default(cuid())
  eventId                 String
  clubId                  String
  memberId                String?
  name                    String
  email                   String
  phone                   String?
  formResponses           Json     @default("{}")
  status                  String   @default("REGISTERED") // REGISTERED | PAID | CANCELED
  amountDue               Decimal? @db.Decimal(10, 2)
  amountPaid              Decimal? @db.Decimal(10, 2)
  // For OFFICIAL variable-cost billing: a Checkout link generated at bill time.
  paymentUrl              String?
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  // Mass-invoice tracking: when the most recent invoice/payment link was sent
  // and how many times this registrant has been invoiced.
  invoicedAt              DateTime?
  invoiceCount            Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([clubId])
  @@index([memberId])
  @@map("event_registrations")
}

// #3: a discounted package of several events sold for one price. Registering
// for the bundle books the member into every included event in one payment.
model EventBundle {
  id          String    @id @default(cuid())
  clubId      String
  name        String
  description String?
  // Single package price for the whole bundle (the deal vs. buying each event
  // separately). Applies to members and non-members alike.
  price       Decimal   @db.Decimal(10, 2)
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  club  Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  items EventBundleItem[]

  @@index([clubId])
  @@map("event_bundles")
}

// Explicit join: which events belong to a bundle.
model EventBundleItem {
  bundleId String
  eventId  String

  bundle EventBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  event  Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([bundleId, eventId])
  @@index([eventId])
  @@map("event_bundle_items")
}

model Booking {
  id        String        @id @default(cuid())
  eventId   String
  memberId  String
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
  @@map("bookings")
}

model Message {
  id          String    @id @default(cuid())
  clubId      String
  senderId    String
  recipientId String
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  club      Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  sender    User @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([recipientId, readAt])
  @@map("messages")
}

model Announcement {
  id          String    @id @default(cuid())
  clubId      String
  title       String
  body        String
  publishAt   DateTime?
  unpublishAt DateTime?
  channels    String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  club        Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  engagements AnnouncementEngagement[]

  @@index([clubId])
  @@map("announcements")
}

model AnnouncementEngagement {
  id             String    @id @default(cuid())
  clubId         String
  announcementId String
  userId         String
  firstSeenAt    DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  openedAt       DateTime?
  openCount      Int       @default(0)
  clickedAt      DateTime?
  clickCount     Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  club         Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([clubId])
  @@index([userId])
  @@map("announcement_engagements")
}

model Transaction {
  id                    String            @id @default(cuid())
  clubId                String
  memberId              String?
  amount                Decimal           @db.Decimal(10, 2)
  platformFee           Decimal?          @db.Decimal(10, 2)
  status                TransactionStatus @default(PENDING)
  stripePaymentIntentId String?           @unique
  description           String?
  stripeChargeId        String?           @unique
  stripeInvoiceId       String?
  stripeSubscriptionId  String?
  type                  String            @default("CHARGE")
  // ── Financial OS ──────────────────────────────────────────────────────
  // Revenue category (memberships, classes, events, products, donations,
  // manual_invoice, cash_payment, sponsorships, other_income …). Null = needs
  // review / uncategorized. Never auto-overwrite an owner's choice.
  category              String?
  // CASH | CARD | STRIPE | BANK | CHECK | OTHER
  paymentMethod         String?           @default("STRIPE")
  // Optional legal entity this money belongs to.
  legalEntityId         String?
  // Free-text payer/source for manual & cash entries.
  source                String?
  notes                 String?
  // True for manually recorded payments / cash / invoices (not from Stripe).
  manual                Boolean           @default(false)
  // Effective accounting date (owner-set for manual entries). Falls back to
  // createdAt for reporting when null.
  txDate                DateTime?
  // Optional FK to the bank/PlaidConnection this money landed in. Lets
  // financials/reports filter by bank account (operating vs foundation).
  plaidConnectionId     String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  club        Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member      Member?      @relation(fields: [memberId], references: [id])
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id])
  plaidConnection PlaidConnection? @relation(fields: [plaidConnectionId], references: [id])
  campaignAttributions CampaignAttribution[]

  @@index([clubId])
  @@index([memberId])
  @@index([legalEntityId])
  @@map("transactions")
}

model Campaign {
  id                    String    @id @default(cuid())
  clubId                String
  name                  String
  type                  String
  status                String    @default("DRAFT") // DRAFT | ACTIVE | SCHEDULED | COMPLETED
  startAt               DateTime?
  endAt                 DateTime?
  audienceFilters       Json      @default("{}")
  linkedAnnouncementIds Json      @default("[]")
  linkedMessageGroupIds Json      @default("[]")
  channelPlan           Json      @default("[]") // email/app now; sms/push future
  revenueAttribution    String    @default("AUTO")
  leadAttribution       String    @default("AUTO")
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  club         Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  attributions CampaignAttribution[]

  @@index([clubId])
  @@index([status])
  @@map("campaigns")
}

model CampaignAttribution {
  id            String    @id @default(cuid())
  clubId        String
  campaignId    String?
  memberId      String?
  transactionId String?
  source        String    @default("UNKNOWN")
  stage         String    @default("NEW")
  revenueAmount Decimal?  @db.Decimal(10, 2)
  firstTouchAt  DateTime  @default(now())
  lastTouchAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  club        Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  campaign    Campaign?    @relation(fields: [campaignId], references: [id])
  member      Member?      @relation(fields: [memberId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@index([clubId])
  @@index([campaignId])
  @@index([memberId])
  @@index([source])
  @@index([stage])
  @@map("campaign_attributions")
}

model Document {
  id                        String    @id @default(cuid())
  clubId                    String
  title                     String
  type                      String
  body                      String?
  required                  Boolean   @default(false)
  publishAt                 DateTime?
  unpublishAt               DateTime?
  expiresAt                 DateTime?
  requiresGuardianSignature Boolean   @default(false)
  // How long a member's signature stays valid before they must re-sign.
  // null = signature is valid indefinitely. Use 365 for annual, 730 for
  // every two years, etc.
  signatureValidForDays     Int?
  deliveryTrigger           String    @default("MANUAL") // MANUAL | MEMBERSHIP | EVENT | MESSAGE
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  deletedAt                 DateTime?

  club       Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  signatures DocumentSignature[]

  @@index([clubId])
  @@map("documents")
}

// Audit log of every Stripe webhook event received. Drives the diagnostics
// page and provides idempotency: if a Stripe event ID is seen twice we skip
// re-processing. Stores the raw payload so failures can be replayed.
model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  livemode      Boolean  @default(false)
  // PLATFORM events arrive on the main account; CONNECT events arrive via
  // Stripe Connect on behalf of a connected club account.
  source        String   @default("PLATFORM") // PLATFORM | CONNECT
  clubId        String?
  processed     Boolean  @default(false)
  errorMessage  String?
  payload       Json
  createdAt     DateTime @default(now())
  processedAt   DateTime?

  @@index([type])
  @@index([clubId])
  @@index([createdAt])
  @@map("stripe_webhook_events")
}

// File metadata for uploads. The file bytes live on disk under
// process.env.UPLOADS_DIR (default ./storage/uploads), keyed by storageKey.
// Files are served only via /api/files/[id] which scopes by clubId, so URLs
// are not world-readable like /public/uploads used to be.
model UploadedFile {
  id            String   @id @default(cuid())
  clubId        String
  uploaderId    String?
  storageKey    String   @unique // disk filename, not the public URL
  originalName  String
  mimeType      String
  sizeBytes     Int
  kind          String   @default("IMAGE") // IMAGE | DOCUMENT | OTHER
  createdAt     DateTime @default(now())

  club     Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  uploader User? @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([clubId])
  @@map("uploaded_files")
}

// Audit trail for member/guardian acknowledgement of a document.
// memberId  = which member the signature applies to (the athlete, possibly a minor).
// signerUserId = which logged-in User clicked "I have read and acknowledge".
// relationship = "SELF" when the member signed for themselves; "GUARDIAN" when a parent/guardian signed for a minor.
model DocumentSignature {
  id            String   @id @default(cuid())
  documentId    String
  memberId      String
  signerUserId  String
  signerName    String
  relationship  String   @default("SELF") // SELF | GUARDIAN
  signedAt      DateTime @default(now())
  ipAddress     String?
  userAgent     String?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  signer   User     @relation(fields: [signerUserId], references: [id], onDelete: Cascade)

  @@unique([documentId, memberId])
  @@index([memberId])
  @@index([documentId])
  @@map("document_signatures")
}

model Expense {
  id            String   @id @default(cuid())
  clubId        String
  description   String
  amount        Decimal  @db.Decimal(10, 2)
  category      String   @default("OTHER")
  // FIXED = same amount every period (rent, insurance, software). VARIABLE =
  // fluctuates (gear, travel, meals). null = unclassified.
  kind          String?
  date          DateTime @default(now())
  isRecurring   Boolean  @default(false)
  notes         String?
  // ── Financial OS ────────────────────────────────────────────────────────
  vendor        String?
  // CASH | CARD | BANK | CHECK | OTHER
  paymentMethod String?
  legalEntityId String?
  reimbursable  Boolean  @default(false)
  // Receipt: private file URL from /api/upload (type=document) or null.
  receiptUrl    String?
  // Optional FK to the PlaidConnection this expense came out of. Lets
  // financials/reports filter by bank account.
  plaidConnectionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  club            Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  legalEntity     LegalEntity?     @relation(fields: [legalEntityId], references: [id])
  plaidConnection PlaidConnection? @relation(fields: [plaidConnectionId], references: [id])

  @@index([clubId])
  @@index([date])
  @@index([legalEntityId])
  @@map("expenses")
}

// Tracked donation / sponsorship for nonprofit & foundation entities.
// Distinct from DonationLink (a reusable Stripe payment link) — this is the
// actual recorded gift for receipts and year-end giving summaries.
model Donation {
  id            String   @id @default(cuid())
  clubId        String
  legalEntityId String?
  donorName     String
  donorEmail    String?
  amount        Decimal  @db.Decimal(10, 2)
  // Fund / program / purpose the gift is designated for.
  fund          String?
  // Restricted = donor-designated for a specific purpose.
  restricted    Boolean  @default(false)
  sponsorship   Boolean  @default(false)
  paymentMethod String   @default("CASH") // CASH | CARD | STRIPE | CHECK | BANK | OTHER
  date          DateTime @default(now())
  receiptUrl    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  club        Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id])

  @@index([clubId])
  @@index([legalEntityId])
  @@index([date])
  @@map("donations")
}

model MessageGroup {
