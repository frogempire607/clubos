# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
backups/*.sql
backups/*.dump

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.env
.env.local

# Private file storage — uploads go here and are served via /api/files/[id]
/storage
/public/uploads
.claude/
.DS_Store

# Native build artifacts
android/.idea/
ios/App/build/
ios/App/Pods/

# Auto-generated by scripts/native-shell-config.mjs on every `npm run cap:sync`.
# Untracked so a release build can't accidentally ship the dev URL — the
# absence of the file means the generator MUST have run to populate it,
# and the generator reads CAPACITOR_SERVER_URL/NEXT_PUBLIC_APP_URL at that time.
public/native-shell/server-config.js
