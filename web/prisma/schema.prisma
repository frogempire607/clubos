model Product {
  id             String    @id @default(cuid())
  clubId         String
  club           Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  price          Decimal   @db.Decimal(10, 2)
  category       String    @default("OTHER") // GEAR | APPAREL | FACILITY | SERVICE | OTHER
  productType    String    @default("GEAR") // GEAR | FACILITY_RENTAL | BIRTHDAY_PARTY | DIGITAL | OTHER
  imageUrl       String?
  active         Boolean   @default(true)
  visibility     String    @default("MEMBERS_AND_PUBLIC") // MEMBERS_ONLY | PUBLIC_ONLY | MEMBERS_AND_PUBLIC | INTERNAL_ONLY
  showLocation   String    @default("MEMBER_PORTAL") // MEMBER_PORTAL | PUBLIC_CHECKOUT | INTERNAL_ONLY
  taxable        Boolean   @default(false)
  internalNotes  String?
  settings       Json      @default("{}")
  trackInventory Boolean   @default(false)
  inventory      Int?
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales ProductSale[]

  @@index([clubId])
  @@map("products")
}

model ProductSale {
  id                      String   @id @default(cuid())
  clubId                  String
  club                    Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  productId               String
  product                 Product  @relation(fields: [productId], references: [id])
  memberId                String?
  member                  Member?  @relation(fields: [memberId], references: [id])
  soldById                String?
  quantity                Int      @default(1)
  unitPrice               Decimal  @db.Decimal(10, 2)
  totalAmount             Decimal  @db.Decimal(10, 2)
  discountCode            String?
  discountAmount          Decimal? @db.Decimal(10, 2)
  notes                   String?
  status                  String   @default("PENDING") // PENDING | COMPLETED | REFUNDED
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([memberId])
  @@map("product_sales")
}

// ── Staff Scheduling ──────────────────────────────────────────────────────────

model StaffAvailability {
  id        String  @id @default(cuid())
  userId    String
  clubId    String
  dayOfWeek Int // 0=Sun 1=Mon … 6=Sat
  startTime String // "09:00" HH:mm
  endTime   String // "17:00" HH:mm
  active    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clubId])
  @@map("staff_availability")
}

model StaffAvailabilityException {
  id        String   @id @default(cuid())
  userId    String
  clubId    String
  date      DateTime // specific date; time portion ignored
  type      String   @default("BLOCKED") // BLOCKED | VACATION | MODIFIED
  startTime String? // custom hours if MODIFIED
  endTime   String?
  note      String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("staff_availability_exceptions")
}

model EventStaffAssignment {
  id      String @id @default(cuid())
  clubId  String
  eventId String
  userId  String
  role    String @default("COACH") // COACH | ASSISTANT | SPOTTER

  club  Club  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([clubId])
  @@index([eventId])
  @@index([userId])
  @@map("event_staff_assignments")
}

// ── Private Lessons ───────────────────────────────────────────────────────────

model PrivateLessonType {
  id               String    @id @default(cuid())
  clubId           String
  locationId       String?
  title            String
  description      String?
  durationMin      Int       @default(60)
  maxAthletes      Int       @default(1)
  basePrice        Decimal   @db.Decimal(10, 2)
  coachTierLabel   String? // display label e.g. "All-American"
  eligibleCoachIds Json      @default("[]") // [userId, …]; empty = any staff
  // Multiple purchase options for ONE lesson type. Each option has its own
  // price and the set of coaches it applies to. Shape:
  // [{ id, label, price, coachIds: string[] }]. Empty = use basePrice +
  // eligibleCoachIds (back-compat).
  priceOptions     Json      @default("[]")
  active           Boolean   @default(true)
  sortOrder        Int       @default(0)
  deletedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club     Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  location Location?              @relation(fields: [locationId], references: [id])
  packages PrivatePackage[]
  bookings PrivateBooking[]
  payRates PrivateLessonPayRate[]

  @@index([clubId])
  @@map("private_lesson_types")
}

model PrivatePackage {
  id               String    @id @default(cuid())
  clubId           String
  lessonTypeId     String? // null = applies to all lesson types
  // New multi-select package eligibility. Empty/null means all lesson types.
  // Back-compat: legacy lessonTypeId is still honored when this list is empty.
  lessonTypeIds    Json      @default("[]")
  title            String
  description      String?
  credits          Int // lessons included
  bonusCredits     Int       @default(0) // e.g. buy 10 get 1 free
  // Pricing model:
  //   FLAT    → `price` is the total prepaid cost for `credits` lessons (legacy).
  //   PERCENT → `discountValue` % off each lesson's tier price; total computed at
  //             purchase based on the chosen lesson type / coach tier price.
  //   FIXED   → `discountValue` $ off each lesson's tier price.
  pricingMode      String    @default("FLAT")
  discountValue    Decimal?  @db.Decimal(10, 2)
  price            Decimal   @db.Decimal(10, 2)
  expiresAfterDays Int? // days after purchase; null = no expiry
  active           Boolean   @default(true)
  // Owner gate for the member-facing package shop. Defaults to false so
  // existing packages stay owner-only until each one is explicitly
  // published — no surprise public exposure on deploy.
  publishedToMembers Boolean @default(false)
  deletedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club       Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  lessonType PrivateLessonType?    @relation(fields: [lessonTypeId], references: [id])
  ledger     PrivateCreditLedger[]

  @@index([clubId])
  @@map("private_packages")
}

model PrivateCreditLedger {
  id           String  @id @default(cuid())
  clubId       String
  memberId     String
  packageId    String?
  lessonTypeId String?

  creditsGranted Int
  creditsUsed    Int @default(0)

  purchaseType String    @default("PACKAGE") // PACKAGE | MANUAL | ADJUSTMENT
  expiresAt    DateTime?
  status       String    @default("active") // active | exhausted | expired | canceled

  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  pricePaid               Decimal? @db.Decimal(10, 2)

  notes        String?
  adjustedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club     Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member   Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  package  PrivatePackage?  @relation(fields: [packageId], references: [id])
  bookings PrivateBooking[]

  @@index([clubId])
  @@index([memberId])
  @@index([status])
  @@map("private_credit_ledger")
}

model PrivateBooking {
  id           String  @id @default(cuid())
  clubId       String
  memberId     String
  lessonTypeId String
  coachId      String?

  // Up to 3 preferred time slots from client: [{ date, startTime, endTime }]
  requestedSlots Json @default("[]")

  confirmedStartAt DateTime?
  confirmedEndAt   DateTime?

  // REQUESTED → PENDING_COACH → CONFIRMED → COMPLETED | CANCELED | DECLINED
  status String @default("REQUESTED")

  creditLedgerId          String?
  paymentType             String? // CREDIT | STRIPE | MANUAL | UNPAID
  pricePaid               Decimal? @db.Decimal(10, 2)
  stripeCheckoutSessionId String?

  allowUnpaid   Boolean @default(false)
  ownerApproved Boolean @default(false)

  canceledAt   DateTime?
  canceledById String?
  cancelReason String?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club         Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member       Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  lessonType   PrivateLessonType    @relation(fields: [lessonTypeId], references: [id])
  coach        User?                @relation("CoachBookings", fields: [coachId], references: [id])
  creditLedger PrivateCreditLedger? @relation(fields: [creditLedgerId], references: [id])
  partners     PrivateBookingPartner[]

  @@index([clubId])
  @@index([memberId])
  @@index([coachId])
  @@index([status])
  @@map("private_bookings")
}

// Additional athletes on a multi-athlete private lesson booking. One row per
// extra participant beyond the primary `PrivateBooking.member`. Only created
// when `PrivateLessonType.maxAthletes > 1` and the booker selects partners.
// 1-on-1 bookings have no rows here — backward compatible.
model PrivateBookingPartner {
  id        String @id @default(cuid())
  clubId    String
  bookingId String

  // MEMBER     — existing member of the club; `memberId` is set
  // OUTSIDE    — non-member; coach approval generates `inviteToken` and the
  //              booker shares the public link to collect info
  // NEEDS_HELP — booker has no partner; coach is asked to find/assign one.
  //              When coach assigns later, kind flips to MEMBER or OUTSIDE.
  kind String

  // MEMBER kind
  memberId String?

  // OUTSIDE kind — filled by the outside partner via the shareable link
  outsideName  String?
  outsideEmail String?
  outsidePhone String?
  // Free-form extras the outside partner submits (e.g. dob, notes).
  outsideInfo  Json?

  // OUTSIDE kind — token used in the public link sent to the booker after
  // coach approval. Unique so it can be looked up directly.
  inviteToken          String?   @unique
  inviteTokenExpiresAt DateTime?

  // PENDING_COACH — coach has not yet approved the parent booking
  // INVITED       — coach approved; OUTSIDE has link, MEMBER has been notified
  // CONFIRMED     — OUTSIDE filled the form, or MEMBER accepted
  // DECLINED      — partner declined participation
  status      String    @default("PENDING_COACH")
  confirmedAt DateTime?
  respondedAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club    Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  booking PrivateBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  member  Member?        @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([clubId])
  @@index([bookingId])
  @@index([memberId])
  @@index([inviteToken])
  @@map("private_booking_partners")
}

model PrivateLessonPayRate {
  id           String  @id @default(cuid())
  clubId       String
  userId       String
  lessonTypeId String
  payType      String // FLAT | PERCENT
  payValue     Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club       Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonType PrivateLessonType @relation(fields: [lessonTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonTypeId])
  @@index([clubId])
  @@map("private_lesson_pay_rates")
}

// ── Modular compensation builder ──────────────────────────────────────────────
// One plan per staff member. Replaces the flat StaffProfile rate fields as the
// authoritative source for payroll. A plan has exactly one base component plus
// any number of stackable bonuses. Assignment rules scope which classes/events/
// memberships/private-lesson-types a component applies to (bonusId null = the
// base component; bonusId set = that bonus). No assignments for a component =
// applies club-wide.
model StaffCompensation {
  id         String   @id @default(cuid())
  clubId     String
  userId     String   @unique
  baseType   String   @default("HOURLY") // SALARY | PER_CLASS | HOURLY
  baseAmount Decimal   @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  club        Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bonuses     CompensationBonus[]
  assignments CompensationAssignment[]

  @@index([clubId])
  @@map("staff_compensations")
}

// Lightweight non-auth contractor / guest coach. No User account, no login.
// Owner logs payments and can later convert to full staff via invite.
model Contractor {
  id              String    @id @default(cuid())
  clubId          String
  name            String
  email           String?
  phone           String?
  role            String? // "Referee", "Photographer", "Guest clinician", ...
  w9Url           String? // private file URL from /api/upload (type=document)
  payoutNotes     String?
  active          Boolean   @default(true)
  // Set when the contractor is converted into a full staff User account.
  convertedUserId String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  club     Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  payments ContractorPayment[]

  @@index([clubId])
  @@map("contractors")
}

// A logged payment / service rendered by a contractor. Feeds future
// payouts/payroll/accounting exports.
model ContractorPayment {
  id           String   @id @default(cuid())
  clubId       String
  contractorId String
  amount       Decimal  @db.Decimal(10, 2)
  date         DateTime @default(now())
  service      String? // what the payment was for
  notes        String?
  createdAt    DateTime @default(now())

  club       Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([contractorId])
  @@map("contractor_payments")
}

model CompensationBonus {
  id             String   @id @default(cuid())
  compensationId String
  // ATTENDANCE   → `amount` $ per athlete attendance on assigned scope
  // SIGNUP       → `amount` $ per athlete who joins/purchases assigned scope
  // REVENUE_SHARE→ `amount` is a percentage (0-100) of revenue from assigned scope
  bonusType      String
  amount         Decimal  @db.Decimal(10, 2)
  // Threshold logic (counts attendees/signups for ATTENDANCE/SIGNUP, or counts
  // of qualifying items for REVENUE_SHARE). Null = no bound.
  //   minThreshold → bonus only starts paying ABOVE this count (e.g. "from
  //                  athlete #11 onward"). Items at or below minThreshold are
  //                  not paid.
  //   maxThreshold → bonus stops paying ABOVE this count (e.g. "caps at 25
  //                  athletes"). Items above maxThreshold are not paid.
  minThreshold   Int?
  maxThreshold   Int?
  createdAt      DateTime @default(now())

  compensation StaffCompensation        @relation(fields: [compensationId], references: [id], onDelete: Cascade)
  assignments  CompensationAssignment[]

  @@index([compensationId])
  @@map("compensation_bonuses")
}

model CompensationAssignment {
  id             String  @id @default(cuid())
  compensationId String
  bonusId        String? // null = scopes the base component; set = scopes that bonus
  scopeType      String  // CLASS | EVENT | MEMBERSHIP | PRIVATE_LESSON_TYPE
  scopeId        String  // RecurringClass / Event / Membership / PrivateLessonType id

  compensation StaffCompensation  @relation(fields: [compensationId], references: [id], onDelete: Cascade)
  bonus        CompensationBonus? @relation(fields: [bonusId], references: [id], onDelete: Cascade)

  @@index([compensationId])
  @@index([bonusId])
  @@index([scopeType, scopeId])
  @@map("compensation_assignments")
}

// ── Recurring Classes ─────────────────────────────────────────────────────────

model RecurringClass {
  id                  String    @id @default(cuid())
  clubId              String
  locationId          String?
  name                String
  description         String?
  daysOfWeek          Json      @default("[]") // [0,1,...,6] — 0=Sun, 1=Mon, ..., 6=Sat
  startTime           String // "09:00" HH:mm — default time, used when a day has no override
  endTime             String // "17:00" HH:mm — default time, used when a day has no override
  // Optional per-day time overrides. Shape: [{ dayOfWeek: 0..6, startTime, endTime }]
  // Days listed here use these times; days NOT listed fall back to startTime/endTime above.
  dayOverrides        Json      @default("[]")
  capacity            Int?
  recurrenceStartDate DateTime
  recurrenceEndDate   DateTime? // null = ongoing; generate 1 yr ahead
  pricingOptions      Json      @default("[]") // [{type:"member"|"nonmember"|"dropin",price:number}]
  assignedStaffIds    Json      @default("[]") // [userId, ...]
  // Owner-chosen calendar color (matches the ClubEventType palette). null =
  // fall back to the generic class color in the calendar grid.
  color               String?
  textColor           String?
  // Who can see this class on the member portal schedule.
  //   PUBLIC        — visible to everyone (logged-in members + future
  //                   public class-finder pages); coach is opting it into
  //                   broad discovery
  //   MEMBERS_ONLY  — visible to any signed-in club member regardless of
  //                   whether they're enrolled in a covering plan
  //   PRIVATE       — invite/roster only; hidden from the member schedule
  // Defaults to MEMBERS_ONLY to preserve the existing behavior.
  visibility          String    @default("MEMBERS_ONLY")
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  club     Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  location Location?      @relation(fields: [locationId], references: [id])
  sessions ClassSession[]

  @@index([clubId])
  @@map("recurring_classes")
}

model ClassSession {
  id        String   @id @default(cuid())
  classId   String
  clubId    String
  date      DateTime
  startsAt  DateTime
  endsAt    DateTime
  canceled  Boolean  @default(false)
  // Per-occurrence overrides. null = inherit the RecurringClass.
  //   staffOverride: userId[] just for this session (substitute / replacement
  //                  coach). [] means "explicitly nobody". null = inherit
  //                  RecurringClass.assignedStaffIds.
  //   note:          one-off instructions for this occurrence.
  //   overridden:    true once any per-occurrence edit was made, so series
  //                  regeneration preserves this row instead of recreating it.
  staffOverride Json?
  note          String?
  overridden    Boolean  @default(false)
  createdAt DateTime @default(now())

  recurringClass RecurringClass     @relation(fields: [classId], references: [id], onDelete: Cascade)
  club           Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  attendance     AttendanceRecord[]

  @@index([classId])
  @@index([clubId])
  @@index([date])
  @@map("class_sessions")
}

// ── Attendance ────────────────────────────────────────────────────────────────

model AttendanceRecord {
  id             String    @id @default(cuid())
  clubId         String
  classSessionId String?
  eventId        String?
  memberId       String
  status         String    @default("PRESENT") // PRESENT | ABSENT | LATE | TRIAL | DROP_IN
  checkedInAt    DateTime?
  addedById      String?
  notes          String?
  // How the at-the-door / non-member fee was settled, for quick display.
  // CASH | COMP | INVOICE | CARD | STRIPE | null. The authoritative money
  // record is the linked Transaction (paymentMethod + status).
  paymentMethod  String?
  amountCharged  Decimal?  @db.Decimal(10, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  club         Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  classSession ClassSession? @relation(fields: [classSessionId], references: [id])
  member       Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  addedBy      User?         @relation("AttendanceAddedBy", fields: [addedById], references: [id])

  @@index([clubId])
  @@index([memberId])
  @@index([classSessionId])
  @@index([eventId])
  @@map("attendance_records")
}

// Per-club email suppression list (CAN-SPAM). Populated by the public
// unsubscribe link in announcement/broadcast emails. Transactional email
// (receipts, activation, password reset) is NOT affected.
model EmailOptOut {
  id        String   @id @default(cuid())
  clubId    String
  email     String
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, email])
  @@map("email_opt_outs")
}
