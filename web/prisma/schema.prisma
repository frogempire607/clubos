generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  STAFF
  MEMBER
}

enum MemberStatus {
  ACTIVE
  PROSPECT
  INACTIVE
  PAUSED
}

enum EventType {
  CLASS
  PRIVATE
  CLINIC
  CAMP
  TOURNAMENT
  OTHER
}

enum BookingStatus {
  CONFIRMED
  WAITLISTED
  CANCELED
  ATTENDED
  NO_SHOW
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Club {
  id                       String    @id @default(cuid())
  name                     String
  slug                     String    @unique
  // Plans: growth | pro | enterprise. There is no free/Starter tier — every
  // club is on at least Growth. Definitions live in lib/tier.ts.
  tier                     String    @default("growth")
  // When true, Stripe processing fees are transparently added to the
  // member/customer's checkout total so the club nets the full amount.
  // Centralized math lives in lib/fees.ts — never hardcode the % elsewhere.
  passProcessingFees       Boolean   @default(false)
  processingFeeNote        String?
  tagline                  String?
  sport                    String?
  primaryColor             String?   @default("#534AB7")
  logoUrl                  String?
  // Stripe Connect (the club's own Stripe account that receives payments)
  stripeAccountId          String?   @unique
  stripeOnboardingComplete Boolean   @default(false)
  stripeChargesEnabled     Boolean   @default(false)
  stripePayoutsEnabled     Boolean   @default(false)
  // ClubOS subscription billing (when the club pays us monthly)
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  subscriptionStatus       String?
  // Plaid bank integration
  plaidAccessToken         String?
  plaidItemId              String?
  notificationPrefs        Json      @default("{}")
  // Member intake form configuration
  // { enabledFields: string[], requiredFields: string[] }
  // When null, the form is in "default" mode (Athlete Name + Email only).
  memberFormConfig         Json?
  // Long-form About Us content for the member portal
  aboutUs                  String?
  // Public-facing club profile
  coverImageUrl            String?
  contactEmail             String?
  contactPhone             String?
  websiteUrl               String?
  // JSON array of {label, url} pairs (Instagram, Facebook, YouTube, …)
  socialLinks              Json      @default("[]")
  // JSON map of {monday: "9-5", tuesday: "...", ...} or free-form blob
  hoursOfOperation         Json?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?

  locations                   Location[]
  users                       User[]
  members                     Member[]
  memberships                 Membership[]
  events                      Event[]
  messages                    Message[]
  announcements               Announcement[]
  transactions                Transaction[]
  documents                   Document[]
  customFields                CustomField[]
  clubEventTypes              ClubEventType[]
  expenses                    Expense[]
  messageGroups               MessageGroup[]
  clubProfile                 ClubProfile?
  legalEntities               LegalEntity[]
  donationLinks               DonationLink[]
  donations                   Donation[]
  // Optional fallback entity stamped on money records when none is chosen.
  defaultLegalEntityId        String?
  discounts                   Discount[]
  products                    Product[]
  productSales                ProductSale[]
  uploadedFiles               UploadedFile[]
  eventRegistrations          EventRegistration[]
  contractors                 Contractor[]
  contractorPayments          ContractorPayment[]
  memberMigrationEvents       MemberMigrationEvent[]
  privateLessonTypes          PrivateLessonType[]
  privatePackages             PrivatePackage[]
  staffAvailability           StaffAvailability[]
  staffAvailabilityExceptions StaffAvailabilityException[]
  eventStaffAssignments       EventStaffAssignment[]
  privateLessonPayRates       PrivateLessonPayRate[]
  privateBookings             PrivateBooking[]
  privateCreditLedger         PrivateCreditLedger[]
  recurringClasses            RecurringClass[]
  classSessions               ClassSession[]
  attendanceRecords           AttendanceRecord[]
  memberRelationships         MemberRelationship[]
  staffCompensations          StaffCompensation[]

  @@index([slug])
  @@map("clubs")
}

model Location {
  id        String    @id @default(cuid())
  clubId    String
  name      String
  address   String?
  // GPS coordinates so member-facing surfaces can deep-link to Apple/Google Maps.
  latitude  Float?
  longitude Float?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  club               Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  events             Event[]
  legalEntities      LegalEntity[]
  privateLessonTypes PrivateLessonType[]
  recurringClasses   RecurringClass[]

  @@index([clubId])
  @@map("locations")
}

model User {
  id            String    @id @default(cuid())
  clubId        String
  email         String
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole  @default(MEMBER)
  emailVerified DateTime?
  resetToken    String?   @unique
  resetExpires  DateTime?
  lastLoginAt   DateTime?
  // Per-user dashboard widget preferences: { order: string[], hidden: string[] }.
  // Null = use sensible defaults.
  dashboardWidgets Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  club                    Club                         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  staffProfile            StaffProfile?
  memberProfile           Member?
  guardianProfile         Guardian?                    @relation("GuardianUser")
  guardianOf              MemberGuardianUser[]         @relation("GuardianLink")
  sentMessages            Message[]                    @relation("Sender")
  receivedMessages        Message[]                    @relation("Recipient")
  messageGroupMemberships MessageGroupMember[]
  sentGroupMessages       GroupMessage[]               @relation("GroupSender")
  availability            StaffAvailability[]
  availabilityExceptions  StaffAvailabilityException[]
  eventAssignments        EventStaffAssignment[]
  coachBookings           PrivateBooking[]             @relation("CoachBookings")
  privateLessonPayRates   PrivateLessonPayRate[]
  attendanceAdded         AttendanceRecord[]           @relation("AttendanceAddedBy")
  documentSignatures      DocumentSignature[]
  uploadedFiles           UploadedFile[]
  compensation            StaffCompensation?

  @@unique([clubId, email])
  @@index([clubId])
  @@index([email])
  @@map("users")
}

model StaffProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  title            String?
  hourlyRate       Decimal? @db.Decimal(10, 2)
  salary           Decimal? @db.Decimal(10, 2)
  appointmentPrice Decimal? @db.Decimal(10, 2)
  // Flat pay per class session taught (in addition to / instead of hourly).
  perSessionRate   Decimal? @db.Decimal(10, 2)
  permissions      Json     @default("{}")
  // Member-portal bio + visible contact (only shown when showOnPortal=true)
  bio              String?
  publicEmail      String?
  publicPhone      String?
  photoUrl         String?
  showOnPortal     Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_profiles")
}

model Member {
  id                   String       @id @default(cuid())
  clubId               String
  userId               String?      @unique
  firstName            String
  lastName             String
  dateOfBirth          DateTime?
  status               MemberStatus @default(PROSPECT)
  membershipId         String?
  tags                 String       @default("")
  notes                String?
  customFieldValues    String       @default("{}")
  joinedAt             DateTime     @default(now())
  email                String?
  phone                String?
  streetAddress        String?
  city                 String?
  state                String?
  zipCode              String?
  gender               String?
  stripeCustomerId     String?
  profileImageUrl      String?
  // Minor / guardian fields
  isMinor              Boolean      @default(false)
  guardianName         String?
  guardianEmail        String?
  guardianPhone        String?
  guardianRelationship String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  deletedAt            DateTime?

  guardianId String?

  // ── Member migration / software-switch ──────────────────────────────────
  // Populated when a member is brought over from another club platform via the
  // migration wizard. Never tier-gated. Imported members are NEVER auto-charged
  // — billing only starts after they activate and add a payment method.
  legacySource             String? // e.g. "Jackrabbit", "Mindbody", "Spreadsheet"
  legacyMemberId           String? // their ID in the old system (for support)
  importedAt               DateTime?
  // null = not a migrated member.
  // IMPORTED | INVITED | ACTIVATED | COMPLETED | FAILED | NEEDS_REVIEW
  migrationStatus          String?
  // null | REQUIRED | COMPLETE
  paymentSetupStatus       String?
  // Legacy membership snapshot (display only until activation creates the sub)
  legacyMembershipName     String?
  legacyMembershipPrice    Decimal? @db.Decimal(10, 2)
  legacyBillingFrequency   String? // WEEKLY | MONTHLY | QUARTERLY | ANNUAL | ...
  membershipStartDate      DateTime?
  nextBillingDate          DateTime?
  // THE key field: when Stripe should take the first charge so billing
  // continues on the member's existing cycle (not on import day).
  billingAnchorDate        DateTime?
  commitmentEndDate        DateTime?
  // Secure activation link
  activationToken          String?  @unique
  activationTokenExpires   DateTime?
  activationEmailSentAt    DateTime?
  activationEmailSendCount Int      @default(0)
  activatedAt              DateTime?
  migrationCompletedAt     DateTime?
  // Owner-assigned plan this migration continues (a real Membership.id).
  // Preferred over the legacy* snapshot when set.
  migrationMembershipId    String?
  // Which fields/abilities the client may edit on the activation page.
  // Shape: { phone, email, billingDateRequest, notes }. null = defaults.
  activationEditableFields Json?
  // Client-submitted requests captured at activation (owner reviews these).
  requestedBillingDate       DateTime?
  requestedBillingNote       String?
  activationNote             String?
  // null | PENDING_APPROVAL | APPROVED. Billing NEVER starts until APPROVED.
  approvalStatus             String?
  // Stripe Customer + PaymentMethod on the club's CONNECTED account, saved
  // via setup-mode checkout. The subscription is created from these only
  // after the owner approves — never at activation time.
  stripeSetupCustomerId      String?
  stripeSetupPaymentMethodId String?

  club              Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user              User?                 @relation(fields: [userId], references: [id])
  membership        Membership?           @relation(fields: [membershipId], references: [id])
  guardian          Guardian?             @relation(fields: [guardianId], references: [id])
  guardianLinks     MemberGuardianUser[]
  bookings          Booking[]
  transactions      Transaction[]
  subscriptions     MemberSubscription[]
  productSales      ProductSale[]
  privateCredits    PrivateCreditLedger[]
  privateBookings   PrivateBooking[]
  attendanceRecords AttendanceRecord[]
  documentSignatures DocumentSignature[]
  eventRegistrations EventRegistration[]
  migrationEvents    MemberMigrationEvent[]
  relationshipsFrom  MemberRelationship[] @relation("RelationshipFrom")
  relationshipsTo    MemberRelationship[] @relation("RelationshipTo")

  @@index([clubId])
  @@index([status])
  @@index([guardianId])
  @@map("members")
}

// Append-only migration audit / history log. One row per meaningful event in a
// member's migration lifecycle (imported, activation sent, reminder, activated,
// completed, failed, note). Never deleted — preserves the legacy paper trail.
model MemberMigrationEvent {
  id        String   @id @default(cuid())
  clubId    String
  memberId  String
  // IMPORTED | ACTIVATION_SENT | REMINDER_SENT | ACTIVATED | COMPLETED |
  // FAILED | NOTE
  type      String
  message   String?
  actorUserId String?
  createdAt DateTime @default(now())

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([memberId])
  @@map("member_migration_events")
}

// A relationship between two members (siblings, cousins, friends, teammates,
// etc). Stored once per pair (memberId < relatedMemberId by convention is NOT
// enforced — the API writes one row and reads both directions). Distinct from
// Guardian/MemberGuardianUser which model legal guardianship + portal access.
model MemberRelationship {
  id              String   @id @default(cuid())
  clubId          String
  memberId        String
  relatedMemberId String
  type            String   // SIBLING | COUSIN | FRIEND | TEAMMATE | PARENT | CHILD | SPOUSE | OTHER
  note            String?
  createdAt       DateTime @default(now())

  club    Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member  Member @relation("RelationshipFrom", fields: [memberId], references: [id], onDelete: Cascade)
  related Member @relation("RelationshipTo", fields: [relatedMemberId], references: [id], onDelete: Cascade)

  @@unique([memberId, relatedMemberId])
  @@index([clubId])
  @@index([memberId])
  @@index([relatedMemberId])
  @@map("member_relationships")
}

model MemberSubscription {
  id           String @id @default(cuid())
  memberId     String
  membershipId String

  // Snapshot of what was purchased
  optionLabel   String
  price         Decimal @default(0) @db.Decimal(10, 2)
  billingPeriod String? // WEEKLY | MONTHLY | … | ONE_TIME — snapshot at purchase
  billingType   String  @default("RECURRING") // RECURRING | ONE_TIME | MANUAL

  // Dates
  startDate DateTime? // when access begins
  endDate   DateTime? // when access expires; null = open-ended recurring

  // Billing control
  autoRenew         Boolean   @default(true)
  billingDay        Int? // 1-28: override billing day of month
  billingAnchorDate DateTime? // resolved anchor datetime passed to Stripe

  // Status: pending → active → past_due → canceled | expired
  status      String    @default("pending")
  pausedAt    DateTime?
  pausedUntil DateTime?
  canceledAt  DateTime?
  expiredAt   DateTime?
  startedAt   DateTime?

  // Stripe
  stripeSubscriptionId    String? @unique
  stripePriceId           String?
  stripeCheckoutSessionId String?

  // Renewal chain — plain string ref to avoid self-relation complexity
  renewedFromId String?

  // Discount applied at purchase
  discountCode   String?
  discountAmount Decimal? @db.Decimal(10, 2)

  // Legacy start mode (kept for backward compat)
  startMode          String    @default("IMMEDIATE") // IMMEDIATE | SPECIFIC_DATE
  effectiveStartDate DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([membershipId])
  @@index([status])
  @@index([endDate])
  @@map("member_subscriptions")
}

// Family / parent profile — one per family identified by primary email.
// Each minor athlete has Member.guardianId pointing here. Adults may also link.
model Guardian {
  id        String   @id @default(cuid())
  clubId    String
  firstName String
  lastName  String
  email     String
  phone     String
  userId    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?    @relation("GuardianUser", fields: [userId], references: [id])
  members Member[]

  @@unique([clubId, email])
  @@index([clubId])
  @@map("guardians")
}

// User <-> Member link for portal access (e.g. parent user account viewing their child's member record).
// Distinct from the Guardian profile model — this records portal access claims, not the family profile.
model MemberGuardianUser {
  id           String   @id @default(cuid())
  userId       String
  memberId     String
  relationship String?
  createdAt    DateTime @default(now())

  user   User   @relation("GuardianLink", fields: [userId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([userId, memberId])
  @@map("member_guardian_users")
}

model Membership {
  id             String  @id @default(cuid())
  clubId         String
  name           String
  description    String?
  options        Json    @default("[]") // [{ label, price, billingPeriod }]
  active         Boolean @default(true)
  purchaseAccess String  @default("ANYONE") // ANYONE | STAFF_ONLY

  // Plan-level defaults & permissions
  autoRenewDefault        Boolean @default(true)
  allowManualRenewal      Boolean @default(true)
  allowCustomDates        Boolean @default(false)
  allowBillingDayOverride Boolean @default(false)
  defaultBillingDay       Int? // 1-28; null = anchor to signup date
  contractMonths          Int? // minimum commitment; null = none

  // Trial rules — when enabled, new subscribers get `trialDays` free before
  // first charge. trialAppliesToReturning controls whether a member can use a
  // trial again after a previous active subscription (default: one-time only).
  trialEnabled            Boolean @default(false)
  trialDays               Int?    // null when disabled; positive integer otherwise
  trialAppliesToReturning Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  club          Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members       Member[]
  subscriptions MemberSubscription[]

  @@index([clubId])
  @@map("memberships")
}

model CustomField {
  id        String   @id @default(cuid())
  clubId    String
  label     String
  fieldType String
  required  Boolean  @default(false)
  options   String   @default("[]")
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@map("custom_fields")
}

model ClubEventType {
  id        String   @id @default(cuid())
  clubId    String
  name      String
  color     String   @default("#F1EFE8")
  textColor String   @default("#5F5E5A")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  events Event[]

  @@index([clubId])
  @@map("club_event_types")
}

model Event {
  id                     String    @id @default(cuid())
  clubId                 String
  locationId             String?
  type                   EventType
  customEventTypeId      String?
  name                   String
  description            String?
  startsAt               DateTime
  endsAt                 DateTime
  capacity               Int?
  memberPrice            Decimal?  @db.Decimal(10, 2)
  nonMemberPrice         Decimal?  @db.Decimal(10, 2)
  dropInFee              Decimal?  @db.Decimal(10, 2)
  travelFee              Decimal?  @db.Decimal(10, 2)
  publishAt              DateTime?
  unpublishAt            DateTime?
  visibility             String    @default("PUBLIC") // PUBLIC | MEMBERS_ONLY | STAFF_ONLY
  purchaseAccess         String    @default("ANYONE") // ANYONE | STAFF_ONLY
  allowMembershipPayment Boolean   @default(false)
  imageUrl               String?
  isTournament           Boolean   @default(false)
  registrationLink       String?
  registrationDeadline   DateTime?
  registrationOpen       Boolean?
  divisions              String?
  pricingOptions         Json?

  // Tournament mode — only meaningful when type=TOURNAMENT.
  //   HOST   = the club is running the tournament; attach a registration form.
  //   ATTEND = the club is taking a team to someone else's tournament; gather
  //            signups and (optionally) split a shared cost across attendees.
  tournamentMode         String?   // HOST | ATTEND

  // Owner-editable registration form. Array of field defs:
  //   [{ id, label, type: "text|email|phone|textarea|select|checkbox", required, options?: string[] }]
  registrationForm       Json?

  // Public (non-member) registration via /e/[publicSlug]
  publicRegistration     Boolean   @default(false)
  publicSlug             String?   @unique
  publicFormIntro        String?

  // Variable cost (ATTEND tournaments): split a shared cost across attendees.
  //   ESTIMATED = charge total / estimatedSignups at signup time.
  //   OFFICIAL  = collect free signups, then bill total / actualSignups after.
  variableCostEnabled         Boolean   @default(false)
  variableCostMode            String?   // ESTIMATED | OFFICIAL
  variableCostTotal           Decimal?  @db.Decimal(10, 2)
  variableCostEstimatedSignups Int?
  // Shown to parents as a "roughly $X each" estimate even in OFFICIAL mode,
  // before the official total is known. Display-only; never billed.
  variableCostEstimatedTotal  Decimal?  @db.Decimal(10, 2)
  variableCostBilledAt        DateTime?

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  club             Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  location         Location?              @relation(fields: [locationId], references: [id])
  customEventType  ClubEventType?         @relation(fields: [customEventTypeId], references: [id])
  bookings         Booking[]
  sessions         EventSession[]
  staffAssignments EventStaffAssignment[]
  registrations    EventRegistration[]

  @@index([clubId])
  @@index([startsAt])
  @@map("events")
}

model EventSession {
  id        String   @id @default(cuid())
  eventId   String
  name      String?
  startsAt  DateTime
  endsAt    DateTime
  sortOrder Int      @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_sessions")
}

// A signup for an Event. Covers BOTH non-member public registrations (via the
// /e/[slug] page) and member registrations. memberId is set only when an
// existing member is matched. formResponses holds answers to the event's
// owner-defined registrationForm.
model EventRegistration {
  id                      String   @id @default(cuid())
  eventId                 String
  clubId                  String
  memberId                String?
  name                    String
  email                   String
  phone                   String?
  formResponses           Json     @default("{}")
  status                  String   @default("REGISTERED") // REGISTERED | PAID | CANCELED
  amountDue               Decimal? @db.Decimal(10, 2)
  amountPaid              Decimal? @db.Decimal(10, 2)
  // For OFFICIAL variable-cost billing: a Checkout link generated at bill time.
  paymentUrl              String?
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  // Mass-invoice tracking: when the most recent invoice/payment link was sent
  // and how many times this registrant has been invoiced.
  invoicedAt              DateTime?
  invoiceCount            Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([clubId])
  @@index([memberId])
  @@map("event_registrations")
}

model Booking {
  id        String        @id @default(cuid())
  eventId   String
  memberId  String
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
  @@map("bookings")
}

model Message {
  id          String    @id @default(cuid())
  clubId      String
  senderId    String
  recipientId String
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  club      Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  sender    User @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([recipientId, readAt])
  @@map("messages")
}

model Announcement {
  id          String    @id @default(cuid())
  clubId      String
  title       String
  body        String
  publishAt   DateTime?
  unpublishAt DateTime?
  channels    String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@map("announcements")
}

model Transaction {
  id                    String            @id @default(cuid())
  clubId                String
  memberId              String?
  amount                Decimal           @db.Decimal(10, 2)
  platformFee           Decimal?          @db.Decimal(10, 2)
  status                TransactionStatus @default(PENDING)
  stripePaymentIntentId String?           @unique
  description           String?
  stripeChargeId        String?           @unique
  stripeInvoiceId       String?
  stripeSubscriptionId  String?
  type                  String            @default("CHARGE")
  // ── Financial OS ──────────────────────────────────────────────────────
  // Revenue category (memberships, classes, events, products, donations,
  // manual_invoice, cash_payment, sponsorships, other_income …). Null = needs
  // review / uncategorized. Never auto-overwrite an owner's choice.
  category              String?
  // CASH | CARD | STRIPE | BANK | CHECK | OTHER
  paymentMethod         String?           @default("STRIPE")
  // Optional legal entity this money belongs to.
  legalEntityId         String?
  // Free-text payer/source for manual & cash entries.
  source                String?
  notes                 String?
  // True for manually recorded payments / cash / invoices (not from Stripe).
  manual                Boolean           @default(false)
  // Effective accounting date (owner-set for manual entries). Falls back to
  // createdAt for reporting when null.
  txDate                DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  club        Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member      Member?      @relation(fields: [memberId], references: [id])
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id])

  @@index([clubId])
  @@index([memberId])
  @@index([legalEntityId])
  @@map("transactions")
}

model Document {
  id                        String    @id @default(cuid())
  clubId                    String
  title                     String
  type                      String
  body                      String?
  required                  Boolean   @default(false)
  publishAt                 DateTime?
  unpublishAt               DateTime?
  expiresAt                 DateTime?
  requiresGuardianSignature Boolean   @default(false)
  // How long a member's signature stays valid before they must re-sign.
  // null = signature is valid indefinitely. Use 365 for annual, 730 for
  // every two years, etc.
  signatureValidForDays     Int?
  deliveryTrigger           String    @default("MANUAL") // MANUAL | MEMBERSHIP | EVENT | MESSAGE
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  deletedAt                 DateTime?

  club       Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  signatures DocumentSignature[]

  @@index([clubId])
  @@map("documents")
}

// Audit log of every Stripe webhook event received. Drives the diagnostics
// page and provides idempotency: if a Stripe event ID is seen twice we skip
// re-processing. Stores the raw payload so failures can be replayed.
model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  livemode      Boolean  @default(false)
  // PLATFORM events arrive on the main account; CONNECT events arrive via
  // Stripe Connect on behalf of a connected club account.
  source        String   @default("PLATFORM") // PLATFORM | CONNECT
  clubId        String?
  processed     Boolean  @default(false)
  errorMessage  String?
  payload       Json
  createdAt     DateTime @default(now())
  processedAt   DateTime?

  @@index([type])
  @@index([clubId])
  @@index([createdAt])
  @@map("stripe_webhook_events")
}

// File metadata for uploads. The file bytes live on disk under
// process.env.UPLOADS_DIR (default ./storage/uploads), keyed by storageKey.
// Files are served only via /api/files/[id] which scopes by clubId, so URLs
// are not world-readable like /public/uploads used to be.
model UploadedFile {
  id            String   @id @default(cuid())
  clubId        String
  uploaderId    String?
  storageKey    String   @unique // disk filename, not the public URL
  originalName  String
  mimeType      String
  sizeBytes     Int
  kind          String   @default("IMAGE") // IMAGE | DOCUMENT | OTHER
  createdAt     DateTime @default(now())

  club     Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  uploader User? @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([clubId])
  @@map("uploaded_files")
}

// Audit trail for member/guardian acknowledgement of a document.
// memberId  = which member the signature applies to (the athlete, possibly a minor).
// signerUserId = which logged-in User clicked "I have read and acknowledge".
// relationship = "SELF" when the member signed for themselves; "GUARDIAN" when a parent/guardian signed for a minor.
model DocumentSignature {
  id            String   @id @default(cuid())
  documentId    String
  memberId      String
  signerUserId  String
  signerName    String
  relationship  String   @default("SELF") // SELF | GUARDIAN
  signedAt      DateTime @default(now())
  ipAddress     String?
  userAgent     String?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  signer   User     @relation(fields: [signerUserId], references: [id], onDelete: Cascade)

  @@unique([documentId, memberId])
  @@index([memberId])
  @@index([documentId])
  @@map("document_signatures")
}

model Expense {
  id            String   @id @default(cuid())
  clubId        String
  description   String
  amount        Decimal  @db.Decimal(10, 2)
  category      String   @default("OTHER")
  date          DateTime @default(now())
  isRecurring   Boolean  @default(false)
  notes         String?
  // ── Financial OS ────────────────────────────────────────────────────────
  vendor        String?
  // CASH | CARD | BANK | CHECK | OTHER
  paymentMethod String?
  legalEntityId String?
  reimbursable  Boolean  @default(false)
  // Receipt: private file URL from /api/upload (type=document) or null.
  receiptUrl    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  club        Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id])

  @@index([clubId])
  @@index([date])
  @@index([legalEntityId])
  @@map("expenses")
}

// Tracked donation / sponsorship for nonprofit & foundation entities.
// Distinct from DonationLink (a reusable Stripe payment link) — this is the
// actual recorded gift for receipts and year-end giving summaries.
model Donation {
  id            String   @id @default(cuid())
  clubId        String
  legalEntityId String?
  donorName     String
  donorEmail    String?
  amount        Decimal  @db.Decimal(10, 2)
  // Fund / program / purpose the gift is designated for.
  fund          String?
  // Restricted = donor-designated for a specific purpose.
  restricted    Boolean  @default(false)
  sponsorship   Boolean  @default(false)
  paymentMethod String   @default("CASH") // CASH | CARD | STRIPE | CHECK | BANK | OTHER
  date          DateTime @default(now())
  receiptUrl    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  club        Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id])

  @@index([clubId])
  @@index([legalEntityId])
  @@index([date])
  @@map("donations")
}

model MessageGroup {
  id          String   @id @default(cuid())
  clubId      String
  name        String
  type        String   @default("GROUP") // GROUP | BROADCAST
  filterType  String? // tag | membership | age | custom | all
  filterValue String?
  createdById String
  createdAt   DateTime @default(now())

  club     Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  messages GroupMessage[]
  members  MessageGroupMember[]

  @@index([clubId])
  @@map("message_groups")
}

model MessageGroupMember {
  id      String @id @default(cuid())
  groupId String
  userId  String

  group MessageGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("message_group_members")
}

model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  senderId  String
  body      String
  createdAt DateTime @default(now())

  group  MessageGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender User         @relation("GroupSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("group_messages")
}

model ClubProfile {
  id     String @id @default(cuid())
  clubId String @unique
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  termForMember     String @default("Member")
  termForCoach      String @default("Coach")
  termForClass      String @default("Class")
  termForEvent      String @default("Event")
  termForMembership String @default("Membership")

  welcomeMessage String?
  accentColor    String?

  portalSections Json @default("[\"schedule\",\"documents\",\"profile\"]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("club_profiles")
}

model LegalEntity {
  id         String    @id @default(cuid())
  clubId     String
  club       Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  name       String
  entityType String
  ein        String?
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  donationLinks DonationLink[]
  transactions  Transaction[]
  expenses      Expense[]
  donations     Donation[]

  @@index([clubId])
  @@map("legal_entities")
}

model DonationLink {
  id                  String       @id @default(cuid())
  clubId              String
  club                Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  legalEntityId       String?
  legalEntity         LegalEntity? @relation(fields: [legalEntityId], references: [id])
  title               String
  description         String?
  url                 String?
  stripePaymentLinkId String?
  active              Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([clubId])
  @@map("donation_links")
}

model Discount {
  id            String    @id @default(cuid())
  clubId        String
  club          Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  code          String
  description   String?
  type          String // PERCENT | FIXED
  value         Decimal   @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int       @default(0)
  active        Boolean   @default(true)
  expiresAt     DateTime?
  membershipIds Json      @default("[]") // [] = all memberships

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubId, code])
  @@index([clubId])
  @@map("discounts")
}

model Product {
  id             String    @id @default(cuid())
  clubId         String
  club           Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  price          Decimal   @db.Decimal(10, 2)
  category       String    @default("OTHER") // GEAR | APPAREL | FACILITY | SERVICE | OTHER
  imageUrl       String?
  active         Boolean   @default(true)
  trackInventory Boolean   @default(false)
  inventory      Int?
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales ProductSale[]

  @@index([clubId])
  @@map("products")
}

model ProductSale {
  id                      String   @id @default(cuid())
  clubId                  String
  club                    Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  productId               String
  product                 Product  @relation(fields: [productId], references: [id])
  memberId                String?
  member                  Member?  @relation(fields: [memberId], references: [id])
  soldById                String?
  quantity                Int      @default(1)
  unitPrice               Decimal  @db.Decimal(10, 2)
  totalAmount             Decimal  @db.Decimal(10, 2)
  discountCode            String?
  discountAmount          Decimal? @db.Decimal(10, 2)
  notes                   String?
  status                  String   @default("PENDING") // PENDING | COMPLETED | REFUNDED
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([memberId])
  @@map("product_sales")
}

// ── Staff Scheduling ──────────────────────────────────────────────────────────

model StaffAvailability {
  id        String  @id @default(cuid())
  userId    String
  clubId    String
  dayOfWeek Int // 0=Sun 1=Mon … 6=Sat
  startTime String // "09:00" HH:mm
  endTime   String // "17:00" HH:mm
  active    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clubId])
  @@map("staff_availability")
}

model StaffAvailabilityException {
  id        String   @id @default(cuid())
  userId    String
  clubId    String
  date      DateTime // specific date; time portion ignored
  type      String   @default("BLOCKED") // BLOCKED | VACATION | MODIFIED
  startTime String? // custom hours if MODIFIED
  endTime   String?
  note      String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("staff_availability_exceptions")
}

model EventStaffAssignment {
  id      String @id @default(cuid())
  clubId  String
  eventId String
  userId  String
  role    String @default("COACH") // COACH | ASSISTANT | SPOTTER

  club  Club  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([clubId])
  @@index([eventId])
  @@index([userId])
  @@map("event_staff_assignments")
}

// ── Private Lessons ───────────────────────────────────────────────────────────

model PrivateLessonType {
  id               String    @id @default(cuid())
  clubId           String
  locationId       String?
  title            String
  description      String?
  durationMin      Int       @default(60)
  maxAthletes      Int       @default(1)
  basePrice        Decimal   @db.Decimal(10, 2)
  coachTierLabel   String? // display label e.g. "All-American"
  eligibleCoachIds Json      @default("[]") // [userId, …]; empty = any staff
  active           Boolean   @default(true)
  sortOrder        Int       @default(0)
  deletedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club     Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  location Location?              @relation(fields: [locationId], references: [id])
  packages PrivatePackage[]
  bookings PrivateBooking[]
  payRates PrivateLessonPayRate[]

  @@index([clubId])
  @@map("private_lesson_types")
}

model PrivatePackage {
  id               String    @id @default(cuid())
  clubId           String
  lessonTypeId     String? // null = applies to all lesson types
  title            String
  description      String?
  credits          Int // lessons included
  bonusCredits     Int       @default(0) // e.g. buy 10 get 1 free
  price            Decimal   @db.Decimal(10, 2)
  expiresAfterDays Int? // days after purchase; null = no expiry
  active           Boolean   @default(true)
  deletedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club       Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  lessonType PrivateLessonType?    @relation(fields: [lessonTypeId], references: [id])
  ledger     PrivateCreditLedger[]

  @@index([clubId])
  @@map("private_packages")
}

model PrivateCreditLedger {
  id           String  @id @default(cuid())
  clubId       String
  memberId     String
  packageId    String?
  lessonTypeId String?

  creditsGranted Int
  creditsUsed    Int @default(0)

  purchaseType String    @default("PACKAGE") // PACKAGE | MANUAL | ADJUSTMENT
  expiresAt    DateTime?
  status       String    @default("active") // active | exhausted | expired | canceled

  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  pricePaid               Decimal? @db.Decimal(10, 2)

  notes        String?
  adjustedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club     Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member   Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  package  PrivatePackage?  @relation(fields: [packageId], references: [id])
  bookings PrivateBooking[]

  @@index([clubId])
  @@index([memberId])
  @@index([status])
  @@map("private_credit_ledger")
}

model PrivateBooking {
  id           String  @id @default(cuid())
  clubId       String
  memberId     String
  lessonTypeId String
  coachId      String?

  // Up to 3 preferred time slots from client: [{ date, startTime, endTime }]
  requestedSlots Json @default("[]")

  confirmedStartAt DateTime?
  confirmedEndAt   DateTime?

  // REQUESTED → PENDING_COACH → CONFIRMED → COMPLETED | CANCELED | DECLINED
  status String @default("REQUESTED")

  creditLedgerId          String?
  paymentType             String? // CREDIT | STRIPE | MANUAL | UNPAID
  pricePaid               Decimal? @db.Decimal(10, 2)
  stripeCheckoutSessionId String?

  allowUnpaid   Boolean @default(false)
  ownerApproved Boolean @default(false)

  canceledAt   DateTime?
  canceledById String?
  cancelReason String?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club         Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member       Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  lessonType   PrivateLessonType    @relation(fields: [lessonTypeId], references: [id])
  coach        User?                @relation("CoachBookings", fields: [coachId], references: [id])
  creditLedger PrivateCreditLedger? @relation(fields: [creditLedgerId], references: [id])

  @@index([clubId])
  @@index([memberId])
  @@index([coachId])
  @@index([status])
  @@map("private_bookings")
}

model PrivateLessonPayRate {
  id           String  @id @default(cuid())
  clubId       String
  userId       String
  lessonTypeId String
  payType      String // FLAT | PERCENT
  payValue     Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club       Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonType PrivateLessonType @relation(fields: [lessonTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonTypeId])
  @@index([clubId])
  @@map("private_lesson_pay_rates")
}

// ── Modular compensation builder ──────────────────────────────────────────────
// One plan per staff member. Replaces the flat StaffProfile rate fields as the
// authoritative source for payroll. A plan has exactly one base component plus
// any number of stackable bonuses. Assignment rules scope which classes/events/
// memberships/private-lesson-types a component applies to (bonusId null = the
// base component; bonusId set = that bonus). No assignments for a component =
// applies club-wide.
model StaffCompensation {
  id         String   @id @default(cuid())
  clubId     String
  userId     String   @unique
  baseType   String   @default("HOURLY") // SALARY | PER_CLASS | HOURLY
  baseAmount Decimal   @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  club        Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bonuses     CompensationBonus[]
  assignments CompensationAssignment[]

  @@index([clubId])
  @@map("staff_compensations")
}

// Lightweight non-auth contractor / guest coach. No User account, no login.
// Owner logs payments and can later convert to full staff via invite.
model Contractor {
  id              String    @id @default(cuid())
  clubId          String
  name            String
  email           String?
  phone           String?
  role            String? // "Referee", "Photographer", "Guest clinician", ...
  w9Url           String? // private file URL from /api/upload (type=document)
  payoutNotes     String?
  active          Boolean   @default(true)
  // Set when the contractor is converted into a full staff User account.
  convertedUserId String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  club     Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  payments ContractorPayment[]

  @@index([clubId])
  @@map("contractors")
}

// A logged payment / service rendered by a contractor. Feeds future
// payouts/payroll/accounting exports.
model ContractorPayment {
  id           String   @id @default(cuid())
  clubId       String
  contractorId String
  amount       Decimal  @db.Decimal(10, 2)
  date         DateTime @default(now())
  service      String? // what the payment was for
  notes        String?
  createdAt    DateTime @default(now())

  club       Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([contractorId])
  @@map("contractor_payments")
}

model CompensationBonus {
  id             String   @id @default(cuid())
  compensationId String
  // ATTENDANCE   → `amount` $ per athlete attendance on assigned scope
  // SIGNUP       → `amount` $ per athlete who joins/purchases assigned scope
  // REVENUE_SHARE→ `amount` is a percentage (0-100) of revenue from assigned scope
  bonusType      String
  amount         Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  compensation StaffCompensation        @relation(fields: [compensationId], references: [id], onDelete: Cascade)
  assignments  CompensationAssignment[]

  @@index([compensationId])
  @@map("compensation_bonuses")
}

model CompensationAssignment {
  id             String  @id @default(cuid())
  compensationId String
  bonusId        String? // null = scopes the base component; set = scopes that bonus
  scopeType      String  // CLASS | EVENT | MEMBERSHIP | PRIVATE_LESSON_TYPE
  scopeId        String  // RecurringClass / Event / Membership / PrivateLessonType id

  compensation StaffCompensation  @relation(fields: [compensationId], references: [id], onDelete: Cascade)
  bonus        CompensationBonus? @relation(fields: [bonusId], references: [id], onDelete: Cascade)

  @@index([compensationId])
  @@index([bonusId])
  @@index([scopeType, scopeId])
  @@map("compensation_assignments")
}

// ── Recurring Classes ─────────────────────────────────────────────────────────

model RecurringClass {
  id                  String    @id @default(cuid())
  clubId              String
  locationId          String?
  name                String
  description         String?
  daysOfWeek          Json      @default("[]") // [0,1,...,6] — 0=Sun, 1=Mon, ..., 6=Sat
  startTime           String // "09:00" HH:mm — default time, used when a day has no override
  endTime             String // "17:00" HH:mm — default time, used when a day has no override
  // Optional per-day time overrides. Shape: [{ dayOfWeek: 0..6, startTime, endTime }]
  // Days listed here use these times; days NOT listed fall back to startTime/endTime above.
  dayOverrides        Json      @default("[]")
  capacity            Int?
  recurrenceStartDate DateTime
  recurrenceEndDate   DateTime? // null = ongoing; generate 1 yr ahead
  pricingOptions      Json      @default("[]") // [{type:"member"|"nonmember"|"dropin",price:number}]
  assignedStaffIds    Json      @default("[]") // [userId, ...]
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  club     Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  location Location?      @relation(fields: [locationId], references: [id])
  sessions ClassSession[]

  @@index([clubId])
  @@map("recurring_classes")
}

model ClassSession {
  id        String   @id @default(cuid())
  classId   String
  clubId    String
  date      DateTime
  startsAt  DateTime
  endsAt    DateTime
  canceled  Boolean  @default(false)
  // Per-occurrence overrides. null = inherit the RecurringClass.
  //   staffOverride: userId[] just for this session (substitute / replacement
  //                  coach). [] means "explicitly nobody". null = inherit
  //                  RecurringClass.assignedStaffIds.
  //   note:          one-off instructions for this occurrence.
  //   overridden:    true once any per-occurrence edit was made, so series
  //                  regeneration preserves this row instead of recreating it.
  staffOverride Json?
  note          String?
  overridden    Boolean  @default(false)
  createdAt DateTime @default(now())

  recurringClass RecurringClass     @relation(fields: [classId], references: [id], onDelete: Cascade)
  club           Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  attendance     AttendanceRecord[]

  @@index([classId])
  @@index([clubId])
  @@index([date])
  @@map("class_sessions")
}

// ── Attendance ────────────────────────────────────────────────────────────────

model AttendanceRecord {
  id             String    @id @default(cuid())
  clubId         String
  classSessionId String?
  eventId        String?
  memberId       String
  status         String    @default("PRESENT") // PRESENT | ABSENT | LATE | TRIAL | DROP_IN
  checkedInAt    DateTime?
  addedById      String?
  notes          String?
  // How the at-the-door / non-member fee was settled, for quick display.
  // CASH | COMP | INVOICE | CARD | STRIPE | null. The authoritative money
  // record is the linked Transaction (paymentMethod + status).
  paymentMethod  String?
  amountCharged  Decimal?  @db.Decimal(10, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  club         Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  classSession ClassSession? @relation(fields: [classSessionId], references: [id])
  member       Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  addedBy      User?         @relation("AttendanceAddedBy", fields: [addedById], references: [id])

  @@index([clubId])
  @@index([memberId])
  @@index([classSessionId])
  @@index([eventId])
  @@map("attendance_records")
}
