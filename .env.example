# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/clubos

# ── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me

# ── Scheduled jobs ───────────────────────────────────────────────────────────
# Shared secret for /api/cron/event-charges, which runs due event-day card
# charges (registrations that chose "charge my saved card on the event date").
# Send it as `Authorization: Bearer <secret>` or `?key=<secret>`.
# UNSET = the endpoint is DISABLED (503), never open — it moves real money.
# Without a scheduler, due charges still run whenever staff open an event's
# registrations; set this + an hourly ping for timely charging.
CRON_SECRET=

# ── Stripe (platform account — receives ClubOS subscription payments) ────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for the ClubOS-own subscription tiers. Create one recurring
# Price per tier in your Stripe dashboard ($50/mo, $99/mo, $199/mo) and paste
# the price IDs here. Test mode and live mode use different IDs.
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Plaid (optional, for bank reconciliation) ────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Email (optional, falls back to console.log if unset) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM="AthletixOS <no-reply@clubos.app>"

# ── File storage ─────────────────────────────────────────────────────────────
# Where uploaded images/docs are written. Defaults to ./storage/uploads if unset.
# Files are NEVER served as static — they go through /api/files/[id] which
# enforces club scoping.
UPLOADS_DIR=

# ── Error tracking (optional) ────────────────────────────────────────────────
# Sentry. Server-side errors and edge runtime errors are reported when SENTRY_DSN
# is set. Browser errors are reported when NEXT_PUBLIC_SENTRY_DSN is set (it has
# to be a public env var for the client bundle to read it). Both can point at
# the same Sentry project or split across two projects.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Sample rate for performance traces. 0.1 = 10% of requests. 1.0 = every one.
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Optional environment tag (e.g. "production", "staging"). Falls back to NODE_ENV.
SENTRY_ENV=
NEXT_PUBLIC_SENTRY_ENV=
# Set to "true" to opt into Sentry Session Replay on the browser. Adds ~50kB JS.
NEXT_PUBLIC_SENTRY_REPLAY=false
